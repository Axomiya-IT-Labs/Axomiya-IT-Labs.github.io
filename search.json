---
layout: null
---
[
  {% assign search_items = "" | split: "" %}
  {% for page_item in site.pages %}
    {% if page_item.title and page_item.url != '/404.html' and page_item.url != '/search.json' %}
    {
      "title": {{ page_item.title | jsonify }},
      "url": {{ page_item.url | relative_url | jsonify }},
      "type": "Page",
      "snippet": {{ page_item.content | strip_html | truncatewords: 20 | jsonify }}
    }{% unless forloop.last and site.projects.size == 0 and site.announcements.size == 0 %},{% endunless %}
    {% endif %}
  {% endfor %}
  {% for proj in site.projects %}
    {
      "title": {{ proj.title | jsonify }},
      "url": {{ proj.url | relative_url | jsonify }},
      "type": "Project",
      "snippet": {{ proj.description | default: proj.content | strip_html | truncatewords: 20 | jsonify }}
    }{% unless forloop.last and site.announcements.size == 0 %},{% endunless %}
  {% endfor %}
  {% for ann in site.announcements %}
    {
      "title": {{ ann.title | jsonify }},
      "url": {{ ann.url | relative_url | jsonify }},
      "type": "Announcement",
      "snippet": {{ ann.excerpt | default: ann.content | strip_html | truncatewords: 20 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
